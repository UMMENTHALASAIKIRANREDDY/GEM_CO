# Copy this to .env.prod and fill in values
# .env.prod is gitignored — never commit it

PORT=4000
BASE_URL=https://aitoolsmigration.cloudfuze.com
SESSION_SECRET=

# MongoDB — same instance as main, different DB names
MONGO_URI=mongodb://admin:PASSWORD@HOST:27017
MONGO_USERNAME=admin
MONGO_PASSWORD=
MONGO_DATABASE=gemco_prod
G2C_DB=gemco_prod
C2G_DB=cogem_prod
S2G_DB=slack2gchat_prod

# Redis / BullMQ
REDIS_URL=redis://localhost:6379
S2G_QUEUE_PREFIX=s2g_prod
MAX_PARALLEL_CHANNELS=5
GLOBAL_MSG_RATE=400
MAX_ZIP_SIZE_MB=5120

# Google Chat (S2G)
GOOGLE_SERVICE_ACCOUNT_KEY=./service_account.json
GOOGLE_ADMIN_SUBJECT=

# Azure / Microsoft 365
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
G2C_APP_ID=
C2G_AZURE_CLIENT_ID=
C2G_AZURE_CLIENT_SECRET=
