# CloudFuze credentials (shared across all customers)

# Server configuration
PORT=3000
BASE_URL=http://localhost:3000
# Production: BASE_URL=http://migcomb.cftools.live

# Microsoft 365 — Multi-tenant Azure AD App
AZURE_CLIENT_ID=your-cloudfuze-client-id-here
AZURE_CLIENT_SECRET=your-cloudfuze-client-secret-here

# Azure OpenAI — Fallback response generator
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-azure-openai-api-key-here
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# Google OAuth 2.0 — For Vault API access (admin sign-in)
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret

# Google — CloudFuze service account (authorized per customer domain)
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=./copilot/copilot/service_account.json

# ── Copilot → Gemini migration options ──────────────────────────────────────
# Graph API options
GRAPH_API_VERSION=v1.0
COPILOT_CHAT_ONLY=true
GRAPH_TOP=100
USERS_ODATA_FILTER=accountEnabled eq true
USERS_PAGE_SIZE=999
SOURCE_TENANT_ID=your-source-tenant-id

# JWT secret (used by C→G auth flows)
JWT_SECRET=generate-a-random-jwt-secret-here

# MongoDB Configuration
MONGO_USERNAME=admin
MONGO_PASSWORD=changeme
MONGO_DATABASE=gemco
MONGO_URI=mongodb://admin:changeme@mongodb:27017/gemco?authSource=admin
