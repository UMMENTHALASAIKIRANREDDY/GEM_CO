# CloudFuze credentials (shared across all customers)
# Copy to .env and fill in real values. DO NOT commit .env to source control.

# ── App ──────────────────────────────────────────────────────────────────────
PORT=3000
BASE_URL=http://localhost:3000
# Production: BASE_URL=https://migcomb.cftools.live
SESSION_SECRET=generate-a-random-32-char-secret
JWT_SECRET=generate-a-random-jwt-secret-here
SHOW_RESET_BUTTON=false

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Base URI — no database name (the factory appends it per database)
MONGO_HOST=mongodb://admin:changeme@mongodb:27017
G2C_DB=gemco
C2G_DB=cogem

# ── G2C: Microsoft 365 (app that writes to OneDrive/OneNote) ─────────────────
AZURE_CLIENT_ID=your-cloudfuze-client-id-here
AZURE_CLIENT_SECRET=your-cloudfuze-client-secret-here

# ── G2C: Azure OpenAI ─────────────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-azure-openai-api-key-here
AZURE_OPENAI_DEPLOYMENT=gpt-4o
# OR: OPENAI_API_KEY=your-openai-api-key

# ── G2C: Google OAuth (admin sign-in for Vault/Drive access) ─────────────────
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret
# Service account JSON path (domain-wide delegation)
GOOGLE_SERVICE_ACCOUNT_PATH=./service_account.json
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=./service_account.json

# ── G2C: Graph API options ────────────────────────────────────────────────────
GRAPH_API_VERSION=v1.0
GRAPH_TOP=100
COPILOT_CHAT_ONLY=true
USERS_ODATA_FILTER=accountEnabled eq true
USERS_PAGE_SIZE=999

# ── C2G: Microsoft (separate Azure app — reads Copilot interactions) ──────────
# This app needs AiInteraction.Read.All application permission in the source tenant
C2G_AZURE_TENANT_ID=your-source-tenant-id
C2G_AZURE_CLIENT_ID=your-c2g-azure-client-id
C2G_AZURE_CLIENT_SECRET=your-c2g-azure-client-secret
C2G_OAUTH_REDIRECT_BASE=http://localhost:3000
# Legacy aliases still read by graphCredentials.js:
SOURCE_TENANT_ID=your-source-tenant-id
SOURCE_AZURE_TENANT_ID=your-source-tenant-id
SOURCE_AZURE_CLIENT_ID=your-c2g-azure-client-id
SOURCE_AZURE_CLIENT_SECRET=your-c2g-azure-client-secret

# ── C2G: Google (service account that writes to destination Drive) ────────────
C2G_GOOGLE_CLIENT_ID=your-c2g-google-client-id
C2G_GOOGLE_CLIENT_SECRET=your-c2g-google-client-secret
